# DB adı: Task  →  örn: createdb "Task"
# Tablo adı: Character (Prisma @@map + migrate ile oluşur)
# Şablon:
#   DATABASE_URL="postgresql://KULLANICI:SIFRE@localhost:5432/Task?schema=public"

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/Task?schema=public"

# Virgülle ayrılmış origin listesi (prod / frontend). Boş bırakılırsa CORS origin: true olur.
CORS_ORIGINS=https://apptrack.ninja,http://localhost:3005
