generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CharacterStatus {
  ALIVE
  DEAD
  UNKNOWN
}

enum CharacterGender {
  MALE
  FEMALE
  UNKNOWN
}

/// PostgreSQL tablo adı: `Character`
model Character {
  id          Int             @id @default(autoincrement())
  image       String
  name        String
  status      CharacterStatus
  gender      CharacterGender
  description String

  @@index([status])
  @@index([gender])
  @@map("Character")
}
